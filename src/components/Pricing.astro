---
const tiers = [
  {
    label: 'Get Online Fast',
    range: 'From $500',
    upkeep: '$50/mo',
    tagline: 'You need a clean, professional presence — fast.',
    outcomes: [
      'Customers find you when they search your name',
      'Looks sharp on any phone or screen',
      'Contact form so leads can reach you directly',
      'Shows up in Google from day one',
      'Hosted on Cloudflare — fast everywhere',
    ],
    popular: false,
    cta: 'Get a Free Quote',
  },
  {
    label: 'Built to Grow',
    range: 'From $1,000',
    upkeep: '$100/mo',
    tagline: 'You want more than a brochure — bookings, accounts, or custom tools.',
    outcomes: [
      'Everything in the starter tier',
      'Online bookings, accounts, or a customer portal',
      'Pulls in real data — menus, inventory, schedules',
      'Built to rank — advanced SEO and schema',
      '30 days of support after launch',
    ],
    popular: true,
    cta: 'Get a Free Quote',
  },
];
---

<section id="pricing" class="py-24 bg-gray-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <p class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center mb-3">
      Investment
    </p>
    <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-4">
      What does it cost?
    </h2>
    <p class="text-gray-400 text-center max-w-xl mx-auto mb-12">
      Most clients are up and running between $500–$2,500. Every project starts with a free conversation — no pressure, no surprises.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto mb-12">
      {tiers.map((tier) => (
        <div
          class={`relative border rounded-xl p-8 flex flex-col transition-colors duration-300 ${
            tier.popular
              ? 'border-emerald-500 bg-gray-950'
              : 'border-gray-800 bg-gray-900 hover:border-emerald-500/50'
          }`}
        >
          {tier.popular && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="bg-emerald-500 text-gray-950 text-xs font-bold px-4 py-1 rounded-full whitespace-nowrap">
                Most Popular
              </span>
            </div>
          )}

          <h3 class="text-xl font-bold text-white mb-1">{tier.label}</h3>
          <p class="text-gray-400 text-sm mb-6">{tier.tagline}</p>

          <div class="mb-8">
            <div class="text-4xl font-bold text-white">
              {tier.range}
            </div>
            <div class="text-sm text-gray-400 mt-1">
              + <span class="text-gray-300 font-medium">{tier.upkeep}</span> upkeep
            </div>
          </div>

          <ul class="space-y-3 mb-8 flex-1">
            {tier.outcomes.map((outcome) => (
              <li class="flex items-start gap-3 text-sm text-gray-300">
                <span class="text-emerald-400 mt-0.5 shrink-0">✓</span>
                {outcome}
              </li>
            ))}
          </ul>

          <a
            href="#contact"
            class={`block text-center font-bold py-3 rounded-lg transition-colors duration-200 ${
              tier.popular
                ? 'bg-emerald-500 hover:bg-emerald-400 text-gray-950'
                : 'border border-gray-700 hover:border-emerald-500/50 text-gray-100 hover:text-emerald-400'
            }`}
          >
            {tier.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="text-center text-gray-400">
      Need something custom?{' '}
      <a href="#contact" class="text-emerald-400 hover:text-emerald-300 font-semibold underline underline-offset-2">
        Let's talk.
      </a>
    </p>

  </div>
</section>
