---
const plans = [
  {
    name: 'Basic',
    price: '$500',
    upkeep: '$50',
    tagline: 'Landing page & simple contact form — live fast, look sharp',
    popular: false,
    features: [
      'Single-page or multi-section landing page',
      'Simple contact form',
      'Mobile-first design',
      'Basic SEO setup',
      'Fast static hosting (Netlify/Vercel)',
      '2 revision rounds',
    ],
  },
  {
    name: 'Pro',
    price: '$1,000',
    upkeep: '$100',
    tagline: 'Full-stack site with user data, auth, or dynamic features',
    popular: true,
    features: [
      'Everything in Basic',
      'Database integration (user accounts, bookings, etc.)',
      'Next.js or equivalent dynamic framework',
      'Custom backend logic & API routes',
      'Advanced SEO + schema markup',
      '3 revision rounds',
      '30-day post-launch support',
    ],
  },
];
---

<section id="pricing" class="py-24 bg-gray-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Label -->
    <p class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center mb-3">
      Pricing
    </p>
    <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-12">
      Simple, Transparent Pricing
    </h2>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto mb-12">
      {plans.map((plan) => (
        <div
          class={`relative border rounded-xl p-8 flex flex-col transition-colors duration-300 ${
            plan.popular
              ? 'border-emerald-500 bg-gray-950'
              : 'border-gray-800 bg-gray-900 hover:border-emerald-500/50'
          }`}
        >
          {/* Most Popular Badge */}
          {plan.popular && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="bg-emerald-500 text-gray-950 text-xs font-bold px-4 py-1 rounded-full whitespace-nowrap">
                Most Popular
              </span>
            </div>
          )}

          <h3 class="text-xl font-bold text-white mb-1">{plan.name}</h3>
          <p class="text-gray-400 text-sm mb-6">{plan.tagline}</p>

          <div class="mb-8">
            <div class="text-4xl font-bold text-white">
              {plan.price}
              <span class="text-base font-normal text-gray-400"> one-time</span>
            </div>
            <div class="text-sm text-gray-400 mt-1">
              + <span class="text-gray-300 font-medium">{plan.upkeep}/mo</span> upkeep
            </div>
          </div>

          <ul class="space-y-3 mb-8 flex-1">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-gray-300">
                <span class="text-emerald-400 mt-0.5 shrink-0">✓</span>
                {feature}
              </li>
            ))}
          </ul>

          <a
            href="#contact"
            class={`block text-center font-bold py-3 rounded-lg transition-colors duration-200 ${
              plan.popular
                ? 'bg-emerald-500 hover:bg-emerald-400 text-gray-950'
                : 'border border-gray-700 hover:border-emerald-500/50 text-gray-100 hover:text-emerald-400'
            }`}
          >
            Get Started
          </a>
        </div>
      ))}
    </div>

    <!-- Custom CTA -->
    <p class="text-center text-gray-400">
      Need something custom?{' '}
      <a href="#contact" class="text-emerald-400 hover:text-emerald-300 font-semibold underline underline-offset-2">
        Let's talk.
      </a>
    </p>
  </div>
</section>
