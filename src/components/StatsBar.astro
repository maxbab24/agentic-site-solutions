---
const stats = [
  { value: '~1', unit: 'week', label: 'typical delivery' },
  { value: '$500', unit: '+', label: 'starting price' },
  { value: 'Free', unit: '', label: 'site audit' },
  { value: 'No', unit: '', label: 'long-term contracts' },
];
---

<div class="border-y border-white/6 py-8" style="background: rgba(16,185,129,0.03);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 sm:gap-4">
      {stats.map((stat, i) => (
        <div
          data-animate="fade-up"
          data-delay={String(i * 80)}
          class="flex flex-col items-center text-center"
        >
          <div class="flex items-baseline gap-1 mb-1">
            <span class="text-3xl sm:text-4xl font-bold text-white" style="font-family:'Syne',sans-serif;">{stat.value}</span>
            {stat.unit && <span class="text-sm text-emerald-400 font-semibold" style="font-family:'DM Mono',monospace;">{stat.unit}</span>}
          </div>
          <p class="text-xs text-gray-500 uppercase tracking-widest" style="font-family:'DM Mono',monospace;">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</div>
