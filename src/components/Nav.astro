---
const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'Portfolio', href: '#portfolio' },
  { label: 'Pricing', href: '#pricing' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/95 backdrop-blur border-b border-gray-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="logo-wordmark group" aria-label="Agentic Site Solutions">
        <span class="logo-top">AGENTIC<span class="logo-slash">/</span></span>
        <span class="logo-bottom">SITE SOLUTIONS</span>
      </a>

      <!-- Nav Links (hidden on mobile) -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-300 hover:text-white text-sm font-medium transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA Button -->
      <a
        href="#contact"
        class="bg-emerald-500 hover:bg-emerald-400 text-gray-950 font-bold text-sm px-4 py-2 rounded-lg transition-colors duration-200 whitespace-nowrap"
      >
        Get a Free Quote
      </a>
    </div>
  </div>
</nav>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@400;500&display=swap');

  .logo-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-decoration: none;
    gap: 1px;
  }

  .logo-top {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: 0.12em;
    color: #ffffff;
    transition: color 0.2s ease;
  }

  .logo-slash {
    color: #10b981;
    margin-left: 1px;
    font-weight: 800;
  }

  .logo-bottom {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 400;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: #6b7280;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .logo-wordmark:hover .logo-top {
    color: #10b981;
  }

  .logo-wordmark:hover .logo-bottom {
    color: #9ca3af;
  }
</style>
