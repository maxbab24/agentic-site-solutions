---
---

<section id="contact" class="py-24 bg-gray-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Label -->
    <p class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center mb-3">
      Contact
    </p>
    <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-4">
      Get a Free Quote
    </h2>
    <p class="text-gray-400 text-center max-w-xl mx-auto mb-14">
      Tell us about your business and we'll get back to you within 24 hours.
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 max-w-4xl mx-auto">
      <!-- Left: Contact Info -->
      <div class="flex flex-col justify-center">
        <h3 class="text-lg font-bold text-white mb-6">Contact Information</h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <span class="text-emerald-400 text-lg mt-0.5">✉</span>
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-0.5">Email</p>
              <a href="mailto:inquiry@agenticsitesolutions.com" class="text-emerald-400 hover:text-emerald-300 text-sm font-medium transition-colors">inquiry@agenticsitesolutions.com</a>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-emerald-400 text-lg mt-0.5">⏱</span>
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-0.5">Response Time</p>
              <p class="text-gray-300 text-sm">Within 24 hours</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-emerald-400 text-lg mt-0.5">🌍</span>
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-0.5">Service Area</p>
              <p class="text-gray-300 text-sm">Nationwide (US)</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div>
        <form id="contact-form" class="space-y-5">
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div>
            <label for="name" class="block text-sm font-semibold text-gray-300 mb-1.5">
              Name
            </label>
            <input
              id="name"
              type="text"
              name="name"
              required
              placeholder="Jane Smith"
              class="w-full bg-gray-900 border border-gray-700 focus:border-emerald-500 text-gray-100 placeholder-gray-600 rounded-lg px-4 py-3 text-sm outline-none transition-colors duration-200"
            />
          </div>

          <div>
            <label for="business" class="block text-sm font-semibold text-gray-300 mb-1.5">
              Business Name
            </label>
            <input
              id="business"
              type="text"
              name="business"
              required
              placeholder="Acme Coffee Co."
              class="w-full bg-gray-900 border border-gray-700 focus:border-emerald-500 text-gray-100 placeholder-gray-600 rounded-lg px-4 py-3 text-sm outline-none transition-colors duration-200"
            />
          </div>

          <div>
            <label for="website" class="block text-sm font-semibold text-gray-300 mb-1.5">
              Current Website URL <span class="font-normal text-gray-500">(optional)</span>
            </label>
            <input
              id="website"
              type="url"
              name="website"
              placeholder="https://yoursite.com — leave blank if you don't have one"
              class="w-full bg-gray-900 border border-gray-700 focus:border-emerald-500 text-gray-100 placeholder-gray-600 rounded-lg px-4 py-3 text-sm outline-none transition-colors duration-200"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-gray-300 mb-1.5">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows={4}
              placeholder="Tell us about your business and what you're looking to achieve..."
              class="w-full bg-gray-900 border border-gray-700 focus:border-emerald-500 text-gray-100 placeholder-gray-600 rounded-lg px-4 py-3 text-sm outline-none transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-emerald-500 hover:bg-emerald-400 text-gray-950 font-bold py-3.5 rounded-lg transition-colors duration-200"
          >
            Send Message
          </button>

          <div id="form-status" class="hidden text-center text-sm py-2 rounded-lg"></div>
        </form>

        <p class="text-center text-gray-500 text-xs mt-4">
          No commitment. No pressure. Just a conversation.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const status = document.getElementById('form-status') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending...';
    status.className = 'hidden';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();

      if (data.ok) {
        form.reset();
        status.textContent = "Message sent! We'll be in touch within 24 hours.";
        status.className = 'text-center text-sm py-2 rounded-lg text-emerald-400 bg-emerald-500/10 border border-emerald-500/20';
        btn.textContent = 'Send Message';
        btn.disabled = false;
      } else {
        throw new Error(data.error || 'Failed');
      }
    } catch (err: any) {
      status.textContent = err?.message || 'Something went wrong. Please email us directly at inquiry@agenticsitesolutions.com';
      status.className = 'text-center text-sm py-2 rounded-lg text-red-400 bg-red-500/10 border border-red-500/20';
      btn.textContent = 'Send Message';
      btn.disabled = false;
    }
  });
</script>
