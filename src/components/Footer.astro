---
const footerLinks = [
  { label: 'Services', href: '#services' },
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'Portfolio', href: '#portfolio' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'Contact', href: '#contact' },
];

const currentYear = new Date().getFullYear();
---

<footer class="section-panel py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center text-center gap-6 mb-12">

      <!-- Wordmark -->
      <a href="/" class="logo-wordmark group" aria-label="Agentic Site Solutions">
        <span class="logo-top">AGENTIC<span class="logo-slash">/</span></span>
        <span class="logo-bottom">SITE SOLUTIONS</span>
      </a>

      <!-- Tagline -->
      <p class="text-gray-500 text-sm max-w-xs leading-relaxed">
        AI-powered website rebuilds for small businesses.<br/>Fast. Affordable. Built to rank.
      </p>

      <!-- Nav Links -->
      <nav class="flex flex-wrap justify-center gap-x-8 gap-y-2">
        {footerLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-500 hover:text-emerald-400 text-xs uppercase tracking-widest transition-colors duration-200"
            style="font-family:'DM Mono',monospace;"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/6 pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-gray-600" style="font-family:'DM Mono',monospace;">&copy; {currentYear} AgenticSiteSolutions</p>
      <p class="text-xs text-gray-600" style="font-family:'DM Mono',monospace;">Built with Astro + AI</p>
    </div>
  </div>
</footer>
