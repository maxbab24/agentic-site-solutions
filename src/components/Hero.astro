---
---

<section
  class="relative min-h-screen flex items-center justify-center bg-gray-950 overflow-hidden"
  style="background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(16, 185, 129, 0.12) 0%, transparent 70%), #030712;"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-32 pt-40">
    <!-- Logo -->
    <img src="/images/logo-full.png" alt="AgenticSiteSolutions" class="h-48 sm:h-64 w-auto mx-auto mb-6" />

    <!-- Badge Pill -->
    <div class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-sm font-semibold px-4 py-1.5 rounded-full mb-8">
      ✦ Shamelessly AI-Powered
    </div>

    <!-- H1 -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 max-w-4xl mx-auto">
      We Use AI to Build Websites.<br class="hidden sm:block" /> That's Why We're Faster and Cheaper.
    </h1>

    <!-- Subheading -->
    <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Most agencies charge $5,000–$15,000 and take months. We ship in days for a fraction of that — because we let AI do the heavy lifting. Curious what that means for your site?
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-14">
      <a
        href="#audit"
        class="w-full sm:w-auto bg-emerald-500 hover:bg-emerald-400 text-gray-950 font-bold px-8 py-3.5 rounded-lg transition-colors duration-200 text-base"
      >
        Scan My Website Free
      </a>
      <a
        href="#how-it-works"
        class="w-full sm:w-auto border border-gray-700 hover:border-emerald-500/50 text-gray-100 hover:text-emerald-400 font-semibold px-8 py-3.5 rounded-lg transition-colors duration-200 text-base"
      >
        How It Works
      </a>
    </div>

    <!-- Stat Pills -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      {[
        { label: 'Days, Not Months', icon: '⚡' },
        { label: 'Fraction of Agency Cost', icon: '💰' },
        { label: 'AI Does the Heavy Lifting', icon: '🤖' },
      ].map((stat) => (
        <div class="flex items-center gap-2 bg-gray-900 border border-gray-800 text-gray-300 text-sm font-semibold px-5 py-2 rounded-full">
          <span>{stat.icon}</span>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
