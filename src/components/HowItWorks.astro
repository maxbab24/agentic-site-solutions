---
const steps = [
  {
    number: '1',
    title: 'Share Your Current Site',
    description:
      'Send us your existing website URL. We analyze your content, branding, and goals.',
  },
  {
    number: '2',
    title: 'AI Builds the Draft',
    description:
      'Our AI workflow reconstructs your site with modern tech — fast hosting, optimized images, and SEO built in from the start.',
  },
  {
    number: '3',
    title: 'We Review, You Approve',
    description:
      'A real person on our team goes through everything before you see it. You get a chance to request changes — we don\'t ship until you\'re happy.',
  },
  {
    number: '4',
    title: 'Launch & Stay in Control',
    description:
      'We go live, connect your domain, and hand you a fast, professional site that\'s ready to bring in customers from day one.',
  },
];
---

<section id="how-it-works" class="py-24 section-panel">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-16 gap-4">
      <div>
        <p data-animate="fade-up" class="text-emerald-400 text-xs font-bold uppercase tracking-widest mb-3" style="font-family:'DM Mono',monospace;">
          Our Process
        </p>
        <h2 data-animate="fade-up" data-delay="100" class="text-3xl sm:text-4xl font-bold text-white">
          How It Works
        </h2>
      </div>
      <p data-animate="fade-up" data-delay="150" class="text-gray-500 text-sm max-w-xs sm:text-right">
        Four steps from your current site to a live, modern one.
      </p>
    </div>

    <div class="flex flex-col divide-y divide-white/6">
      {steps.map((step, i) => (
        <div
          data-animate="fade-up"
          data-delay={String((i + 1) * 100)}
          class="grid grid-cols-[4rem_1fr] sm:grid-cols-[6rem_1fr_2fr] gap-x-6 sm:gap-x-10 py-8 items-start group"
        >
          <span class="step-num text-5xl sm:text-6xl font-bold leading-none text-white/10 group-hover:text-emerald-500/30 transition-colors duration-500 select-none" style="font-family:'DM Mono',monospace;">
            {String(i + 1).padStart(2, '0')}
          </span>
          <h3 class="text-lg sm:text-xl font-bold text-white pt-1 sm:pt-2">{step.title}</h3>
          <p class="col-start-2 sm:col-start-3 text-gray-400 leading-relaxed mt-2 sm:mt-0 sm:pt-2">{step.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
