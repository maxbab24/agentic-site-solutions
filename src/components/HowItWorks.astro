---
const steps = [
  {
    number: '1',
    title: 'Share Your Current Site',
    description:
      'Send us your existing website URL. We analyze your content, branding, and goals.',
  },
  {
    number: '2',
    title: 'AI Builds the Draft',
    description:
      'Our AI workflow reconstructs your site with modern tech — fast hosting, optimized images, and SEO built in from the start.',
  },
  {
    number: '3',
    title: 'We Review, You Approve',
    description:
      'A real person on our team goes through everything before you see it. You get a chance to request changes — we don\'t ship until you\'re happy.',
  },
  {
    number: '4',
    title: 'Launch & Stay in Control',
    description:
      'We go live, connect your domain, and hand you a fast, professional site that\'s ready to bring in customers from day one.',
  },
];
---

<section id="how-it-works" class="py-24 bg-gray-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Label -->
    <p class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center mb-3">
      Our Process
    </p>
    <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-16">
      How It Works
    </h2>

    <!-- Steps -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10">
      {steps.map((step) => (
        <div class="flex flex-col items-center text-center md:items-start md:text-left">
          <!-- Number Circle -->
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-emerald-500 text-gray-950 font-bold text-xl mb-6 shrink-0">
            {step.number}
          </div>
          <h3 class="text-xl font-bold text-white mb-3">{step.title}</h3>
          <p class="text-gray-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
