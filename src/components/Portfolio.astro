---
const caseStudy = {
  name: 'Habanero Mexican Cafe',
  location: 'Austin, TX',
  description:
    'Rebuilt a 27-year-old family Mexican restaurant\'s outdated site. Full menu in HTML, JSON-LD schema, WebP images, mobile-first design.',
  tags: ['Restaurant', 'Local SEO', 'Astro', 'Tailwind'],
};
---

<section id="portfolio" class="py-24 bg-gray-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Label -->
    <p class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center mb-3">
      Our Work
    </p>
    <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-12">
      Recent Work
    </h2>

    <!-- Case Study Card -->
    <div class="max-w-2xl mx-auto mb-12">
      <div class="border border-gray-800 bg-gray-900 hover:border-emerald-500/50 rounded-xl p-8 transition-colors duration-300">
        <!-- Header -->
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h3 class="text-xl font-bold text-white">{caseStudy.name}</h3>
            <p class="text-emerald-400 text-sm font-medium mt-0.5">
              📍 {caseStudy.location}
            </p>
          </div>
          <span class="shrink-0 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-xs font-semibold px-3 py-1 rounded-full">
            Live Project
          </span>
        </div>

        <!-- Description -->
        <p class="text-gray-400 leading-relaxed mb-6">{caseStudy.description}</p>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2">
          {caseStudy.tags.map((tag) => (
            <span class="bg-gray-800 text-gray-300 text-xs font-medium px-3 py-1 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Coming Soon -->
    <div class="text-center border border-dashed border-gray-800 rounded-xl py-12 px-6">
      <p class="text-gray-500 text-base">
        More case studies coming soon — we're just getting started.
      </p>
    </div>
  </div>
</section>
