---
const values = [
  {
    icon: '🤖',
    title: 'AI Builds It. We Ship It.',
    description:
      'We use AI systems to analyze, design, and build your site — the same technology powering the biggest companies in the world, now working for your small business.',
  },
  {
    icon: '⚡',
    title: 'Days, Not Months',
    description:
      'Traditional agencies bill for hours. We automate the slow parts and pass the time savings to you. Most sites go live within a week.',
  },
  {
    icon: '💰',
    title: 'Half the Price',
    description:
      'No bloated agency overhead. No account managers who just forward emails. You get a professional result at a price that actually makes sense.',
  },
  {
    icon: '👀',
    title: 'Human Eyes on Everything',
    description:
      'AI does the heavy lifting, but a real person reviews every site before it ships. You get dedicated revision rounds to make sure it\'s exactly what you envisioned.',
  },
];
---

<section class="py-24 bg-gray-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <p data-animate="fade-up" class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center mb-3">
      How We're Different
    </p>
    <h2 data-animate="fade-up" data-delay="100" class="text-3xl sm:text-4xl font-bold text-white text-center mb-4">
      AI isn't the future of web design.<br class="hidden sm:block" /> It's how we build right now.
    </h2>
    <p data-animate="fade-up" data-delay="200" class="text-gray-400 text-center max-w-xl mx-auto mb-12">
      We're not hiding it — we lean on AI hard. It's why our quality is high, our turnaround is fast, and our prices don't make you wince.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
      {values.map((value, i) => (
        <div
          data-animate="fade-up"
          data-delay={String((i + 1) * 100)}
          class="border border-gray-800 bg-gray-900 hover:border-emerald-500/50 rounded-xl p-8 transition-colors duration-300"
        >
          <div class="text-4xl mb-5">{value.icon}</div>
          <h3 class="text-xl font-bold text-white mb-3">{value.title}</h3>
          <p class="text-gray-400 leading-relaxed">{value.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
