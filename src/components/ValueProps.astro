---
const values = [
  {
    icon: '⚡',
    title: 'AI-Powered Speed',
    description:
      'What takes traditional agencies weeks, we deliver in days. Our AI workflow scrapes, analyzes, and rebuilds your site automatically.',
  },
  {
    icon: '💰',
    title: 'Fraction of the Cost',
    description:
      'No bloated agency fees. No middlemen. We pass the savings directly to you — professional results at indie prices.',
  },
  {
    icon: '🔍',
    title: 'Built to Be Found',
    description:
      'Every site ships with schema markup, WebP images, sitemap, Open Graph tags, and local SEO baked in from day one.',
  },
];
---

<section class="py-24 bg-gray-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Label -->
    <p class="text-emerald-400 text-xs font-bold uppercase tracking-widest text-center mb-3">
      Why Choose Us
    </p>
    <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-12">
      Everything You Need, Nothing You Don't
    </h2>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {values.map((value) => (
        <div class="border border-gray-800 bg-gray-900 hover:border-emerald-500/50 rounded-xl p-8 transition-colors duration-300">
          <div class="text-4xl mb-5">{value.icon}</div>
          <h3 class="text-xl font-bold text-white mb-3">{value.title}</h3>
          <p class="text-gray-400 leading-relaxed">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
